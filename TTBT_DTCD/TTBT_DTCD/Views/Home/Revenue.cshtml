@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@model IEnumerable<TTBT_DTCD.Models.DoanhThu>
@{ ViewData["Title"] = "Quản lý doanh thu - Trung Tâm Bảo Tồn Di Tích Cố Đô Huế";
   var role = HttpContextAccessor.HttpContext?.Session.GetString("Role"); }

@if (TempData["Message"] != null) { <div class="alert alert-success"><i class="ti ti-check-circle"></i> @TempData["Message"]</div> }
@if (TempData["Error"]   != null) { <div class="alert alert-danger"><i class="ti ti-alert-triangle"></i> @TempData["Error"]</div> }

<div class="kpi-grid-4">
  <div class="kpi-card">
    <i class="ti ti-trending-up" style="color:#1a4fa0"></i>
    <div class="kpi-label">Tổng doanh thu</div>
    <div class="kpi-value">@Model.Sum(x=>x.SoTien).ToString("N0")đ</div>
    <div class="kpi-unit" style="color:#0f6e56">tất cả thời gian</div>
  </div>
  <div class="kpi-card">
    <i class="ti ti-ticket" style="color:#0f6e56"></i>
    <div class="kpi-label">Doanh thu bán vé</div>
    <div class="kpi-value">@Model.Where(x=>x.LoaiDoanhThu=="Bán vé").Sum(x=>x.SoTien).ToString("N0")đ</div>
    <div class="kpi-unit" style="color:#0f6e56">▲ 8.3% so với kỳ trước</div>
  </div>
  <div class="kpi-card">
    <i class="ti ti-tools-kitchen" style="color:#854f0b"></i>
    <div class="kpi-label">Doanh thu dịch vụ khác</div>
    <div class="kpi-value">@Model.Where(x=>x.LoaiDoanhThu!="Bán vé").Sum(x=>x.SoTien).ToString("N0")đ</div>
    <div class="kpi-unit" style="color:#0f6e56">▲ 15.7% so với kỳ trước</div>
  </div>
  <div class="kpi-card">
    <i class="ti ti-receipt" style="color:#533ab7"></i>
    <div class="kpi-label">Số giao dịch</div>
    <div class="kpi-value">@Model.Count()</div>
    <div class="kpi-unit" style="color:#0f6e56">▲ 10.1% so với kỳ trước</div>
  </div>
</div>

<div class="charts-row-2">
  <div class="card-nm">
    <div class="card-title"><i class="ti ti-chart-bar" style="color:#1a4fa0"></i>BIỂU ĐỒ DOANH THU THEO THỜI GIAN</div>
    <div class="legend-row">
      <span class="legend-item"><span class="ldot" style="background:#1a4fa0"></span>Doanh thu bán vé</span>
      <span class="legend-item"><span class="ldot" style="background:#f5c518"></span>Doanh thu dịch vụ khác</span>
    </div>
    <div style="position:relative;height:220px"><canvas id="revBarChart"></canvas></div>
  </div>
  <div class="card-nm">
    <div class="card-title"><i class="ti ti-chart-pie" style="color:#854f0b"></i>TỶ TRỌNG DOANH THU</div>
    <div style="position:relative;height:160px;margin-bottom:10px"><canvas id="revPieChart"></canvas></div>
    <div style="font-size:11px;color:#555;display:flex;flex-direction:column;gap:5px">
      <div class="legend-item"><span class="ldot" style="background:#1a4fa0"></span>Vé: @Model.Where(x=>x.LoaiDoanhThu=="Bán vé").Sum(x=>x.SoTien).ToString("N0")đ</div>
      <div class="legend-item"><span class="ldot" style="background:#f5c518"></span>Dịch vụ: @Model.Where(x=>x.LoaiDoanhThu!="Bán vé").Sum(x=>x.SoTien).ToString("N0")đ</div>
    </div>
  </div>
</div>

<div class="filter-bar">
  <input type="text" id="search" placeholder="Tìm kiếm..." style="flex:1;max-width:220px"/>
  <select id="loai-filter">
    <option value="">Tất cả loại doanh thu</option>
    <option>Bán vé</option><option>Dịch vụ lưu trú</option><option>Dịch vụ ăn uống</option>
  </select>
  <select id="diem-filter">
    <option value="">Tất cả điểm thu</option>
    <option>Đại Nội</option><option>Lăng Khải Định</option><option>Chùa Thiên Mụ</option><option>Hoàng Thành Huế</option>
  </select>
  <a asp-action="CreateDoanhThu" class="btn-action btn-blue"><i class="ti ti-plus"></i> Thêm mới</a>
</div>

<div class="card-nm" style="padding:0;overflow:hidden">
  <table class="tbl" id="tbl">
    <thead><tr><th>Ngày</th><th>Loại doanh thu</th><th>Số tiền (đồng)</th><th>Điểm thu</th><th>NV phụ trách</th><th>NV lập</th><th style="text-align:center">Thao tác</th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
      string bc = item.LoaiDoanhThu=="Bán vé"?"b-blue":item.LoaiDoanhThu.Contains("lưu trú")?"b-green":"b-amber";
      <tr data-s="@(item.LoaiDoanhThu+" "+item.DiemThu+" "+item.NhanVienPhuTrach).ToLower()" data-loai="@item.LoaiDoanhThu" data-diem="@item.DiemThu">
        <td>@item.Ngay.ToString("dd/MM/yyyy")</td>
        <td><span class="badge @bc">@item.LoaiDoanhThu</span></td>
        <td><strong>@item.SoTien.ToString("N0")</strong></td>
        <td>@item.DiemThu</td>
        <td>@item.NhanVienPhuTrach</td>
        <td>@item.NhanVienLap</td>
        <td class="action-icons" style="text-align:center">
          <a asp-action="EditDoanhThu" asp-route-id="@item.Id"><i class="ti ti-pencil" style="color:#854f0b" title="Sửa"></i></a>
          @if (role=="Admin") {
            <form asp-action="DeleteDoanhThu" method="post" style="display:inline" onsubmit="return confirm('Xóa bản ghi này?')">
              <input type="hidden" name="id" value="@item.Id"/>
              <button type="submit" style="border:none;background:none;cursor:pointer"><i class="ti ti-trash" style="color:#a32d2d" title="Xóa"></i></button>
            </form>
          }
        </td>
      </tr>
    }
    </tbody>
  </table>
</div>

<script>
  const rows=document.querySelectorAll("#tbl tbody tr");
  function f(){const q=document.getElementById("search").value.toLowerCase(),l=document.getElementById("loai-filter").value,d=document.getElementById("diem-filter").value;rows.forEach(r=>{r.style.display=(r.dataset.s.includes(q)&&(!l||r.dataset.loai===l)&&(!d||r.dataset.diem===d))?"":"none"});}
  document.getElementById("search").addEventListener("input",f);
  document.getElementById("loai-filter").addEventListener("change",f);
  document.getElementById("diem-filter").addEventListener("change",f);

  const bv=@Model.Where(x=>x.LoaiDoanhThu=="Bán vé").Sum(x=>x.SoTien),dv=@Model.Where(x=>x.LoaiDoanhThu!="Bán vé").Sum(x=>x.SoTien),tc="#999";
  new Chart(document.getElementById("revBarChart"),{type:"bar",data:{labels:["Bán vé","Dịch vụ khác"],datasets:[{data:[bv,dv],backgroundColor:["#1a4fa0","#f5c518"],borderRadius:4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{display:false},ticks:{color:tc}},y:{ticks:{color:tc}}}}});
  new Chart(document.getElementById("revPieChart"),{type:"pie",data:{labels:["Bán vé","Dịch vụ"],datasets:[{data:[bv,dv],backgroundColor:["#1a4fa0","#f5c518"],borderWidth:0}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}}}});
</script>
