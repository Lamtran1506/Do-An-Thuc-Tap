@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@model IEnumerable<TTBT_DTCD.Models.Ve>
@{ ViewData["Title"] = "Quản lý vé - Trung Tâm Bảo Tồn Di Tích Cố Đô Huế";
   var role = HttpContextAccessor.HttpContext?.Session.GetString("Role"); }

@if (TempData["Message"] != null) { <div class="alert alert-success"><i class="ti ti-check-circle"></i> @TempData["Message"]</div> }
@if (TempData["Error"]   != null) { <div class="alert alert-danger"><i class="ti ti-alert-triangle"></i> @TempData["Error"]</div> }

<div class="kpi-grid-4">
  <div class="kpi-card"><i class="ti ti-ticket" style="color:#1a4fa0"></i><div class="kpi-label">Tổng vé</div><div class="kpi-value">@Model.Count()</div><div class="kpi-unit">vé</div></div>
  <div class="kpi-card"><i class="ti ti-user-check" style="color:#0f6e56"></i><div class="kpi-label">Người lớn</div><div class="kpi-value">@Model.Count(x=>x.LoaiVe=="Người lớn")</div><div class="kpi-unit">vé</div></div>
  <div class="kpi-card"><i class="ti ti-user" style="color:#854f0b"></i><div class="kpi-label">Trẻ em</div><div class="kpi-value">@Model.Count(x=>x.LoaiVe=="Trẻ em")</div><div class="kpi-unit">vé</div></div>
  <div class="kpi-card"><i class="ti ti-id" style="color:#533ab7"></i><div class="kpi-label">Ưu tiên</div><div class="kpi-value">@Model.Count(x=>x.LoaiVe=="Ưu tiên")</div><div class="kpi-unit">vé</div></div>
</div>

<div class="charts-row-2" style="grid-template-columns:2fr 1fr;gap:16px;margin-bottom:16px">
  <div class="card-nm">
    <div class="card-title" style="display:flex;justify-content:space-between;align-items:center">
      <span><i class="ti ti-chart-bar" style="color:#1a4fa0"></i> SỐ LƯỢNG VÉ BÁN THEO ĐIỂM DI TÍCH VÀ ĐỐI TƯỢNG</span>
      <div class="legend-row" style="margin-bottom:0">
        <span class="legend-item"><span class="ldot" style="background:#1a4fa0"></span>Người lớn</span>
        <span class="legend-item"><span class="ldot" style="background:#f5c518"></span>Trẻ em</span>
        <span class="legend-item"><span class="ldot" style="background:#e07b39"></span>Ưu tiên</span>
      </div>
    </div>
    <div style="position:relative;height:210px;margin-top:15px"><canvas id="ticketLocationChart"></canvas></div>
  </div>
  <div class="card-nm">
    <div class="card-title"><i class="ti ti-chart-pie" style="color:#0f6e56"></i> TRẠNG THÁI VÉ</div>
    <div style="position:relative;height:150px;margin-top:10px;margin-bottom:10px"><canvas id="ticketStatusChart"></canvas></div>
    <div style="font-size:11px;color:#555;display:flex;flex-direction:column;gap:5px">
      <div class="legend-item"><span class="ldot" style="background:#0f6e56"></span>Chưa sử dụng: @Model.Count(x=>x.TrangThai=="Chưa sử dụng")</div>
      <div class="legend-item"><span class="ldot" style="background:#666"></span>Đã sử dụng: @Model.Count(x=>x.TrangThai=="Đã sử dụng")</div>
      <div class="legend-item"><span class="ldot" style="background:#a32d2d"></span>Đã hoàn trả: @Model.Count(x=>x.TrangThai=="Đã hoàn trả")</div>
    </div>
  </div>
</div>

<div class="filter-bar">
  <select id="loai-filter"><option value="">Tất cả loại vé</option><option>Người lớn</option><option>Trẻ em</option><option>Ưu tiên</option></select>
  <select id="tt-filter"><option value="">Tất cả trạng thái</option><option>Chưa sử dụng</option><option>Đã sử dụng</option><option>Đã hoàn trả</option></select>
  <input type="text" id="search" placeholder="Nhập mã vé hoặc điểm bán..." style="flex:1;max-width:250px"/>
  <a asp-action="CreateVe" class="btn-action btn-blue"><i class="ti ti-plus"></i> Thêm vé</a>
</div>

<div class="card-nm" style="padding:0;overflow:hidden">
  <table class="tbl" id="tbl">
    <thead><tr><th>Mã Vé</th><th>Loại Vé</th><th>Giá Vé (đồng)</th><th>Ngày Bán</th><th>Điểm Tham Quan</th><th>NV Bán</th><th>Trạng Thái</th><th style="text-align:center">Thao Tác</th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
      string bc=item.LoaiVe=="Người lớn"?"b-blue":item.LoaiVe=="Trẻ em"?"b-amber":"b-red";
      string tc=item.TrangThai=="Chưa sử dụng"?"b-green":item.TrangThai=="Đã sử dụng"?"b-gray":"b-red";
      <tr data-s="@(item.MaVe+" "+item.DiemBan).ToLower()" data-loai="@item.LoaiVe" data-tt="@item.TrangThai">
        <td><strong>@item.MaVe</strong></td>
        <td><span class="badge @bc">@item.LoaiVe</span></td>
        <td><strong>@item.GiaVe.ToString("N0")</strong></td>
        <td>@item.NgayBan.ToString("dd/MM/yyyy")</td>
        <td>@item.DiemBan</td>
        <td>@item.NhanVienBan</td>
        <td><span class="badge @tc">@item.TrangThai</span></td>
        <td class="action-icons" style="text-align:center">
          <a asp-action="EditVe" asp-route-id="@item.Id"><i class="ti ti-pencil" style="color:#854f0b" title="Sửa"></i></a>
          @if (role=="Admin") {
            <form asp-action="DeleteVe" method="post" style="display:inline" onsubmit="return confirm('Xóa vé này?')">
              <input type="hidden" name="id" value="@item.Id"/>
              <button type="submit" style="border:none;background:none;cursor:pointer"><i class="ti ti-trash" style="color:#a32d2d"></i></button>
            </form>
          }
        </td>
      </tr>
    }
    </tbody>
  </table>
</div>

<script>
  const rows=document.querySelectorAll("#tbl tbody tr");
  function f(){const q=document.getElementById("search").value.toLowerCase(),l=document.getElementById("loai-filter").value,t=document.getElementById("tt-filter").value;rows.forEach(r=>{r.style.display=(r.dataset.s.includes(q)&&(!l||r.dataset.loai===l)&&(!t||r.dataset.tt===t))?"":"none"});}
  document.getElementById("search").addEventListener("input",f);
  document.getElementById("loai-filter").addEventListener("change",f);
  document.getElementById("tt-filter").addEventListener("change",f);

  const tc="#999",gc="rgba(0,0,0,0.05)";
  new Chart(document.getElementById("ticketLocationChart"),{type:"bar",data:{labels:["Đại Nội Huế","Lăng Khải Định","Lăng Minh Mạng","Lăng Tự Đức"],datasets:[{label:"Người lớn",data:[3400,1500,1200,740],backgroundColor:"#1a4fa0",borderRadius:2},{label:"Trẻ em",data:[1800,950,600,385],backgroundColor:"#f5c518",borderRadius:2},{label:"Ưu tiên",data:[980,420,310,165],backgroundColor:"#e07b39",borderRadius:2}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{display:false},ticks:{color:tc,font:{size:10}}},y:{grid:{color:gc},ticks:{color:tc,font:{size:10}}}}}});
  new Chart(document.getElementById("ticketStatusChart"),{type:"doughnut",data:{labels:["Chưa sử dụng","Đã sử dụng","Đã hoàn trả"],datasets:[{data:[@Model.Count(x=>x.TrangThai=="Chưa sử dụng"),@Model.Count(x=>x.TrangThai=="Đã sử dụng"),@Model.Count(x=>x.TrangThai=="Đã hoàn trả")],backgroundColor:["#0f6e56","#666666","#a32d2d"],borderWidth:0,hoverOffset:4}]},options:{responsive:true,maintainAspectRatio:false,cutout:"65%",plugins:{legend:{display:false}}}});
</script>
