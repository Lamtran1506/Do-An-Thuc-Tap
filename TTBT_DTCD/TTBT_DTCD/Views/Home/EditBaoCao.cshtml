@model TTBT_DTCD.Models.BaoCao
@{ ViewData["Title"] = "Sửa báo cáo"; }
<style>.form-page{max-width:680px;margin:0 auto}.form-card{background:#fff;border-radius:10px;border:1px solid #e8e8e8;padding:24px}.form-header{display:flex;align-items:center;gap:10px;margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid #f0f0f0}.form-header i{font-size:22px;color:#1a4fa0}.form-header h2{font-size:15px;font-weight:700;color:#1a1a1a;margin:0}.form-footer{display:flex;gap:10px;justify-content:flex-end;margin-top:20px;padding-top:14px;border-top:1px solid #f0f0f0}</style>
<div class="form-page">
  <div class="form-card">
    <div class="form-header"><i class="ti ti-pencil"></i><h2>Sửa báo cáo</h2></div>
    <form asp-action="EditBaoCao" method="post">
      <input type="hidden" asp-for="Id"/>
      <div class="form-section">
        <div class="form-group full"><label>Ngày báo cáo</label><input asp-for="Ngay" type="date"/><span asp-validation-for="Ngay" class="form-error"></span></div>
        <div class="form-group"><label>Số vé bán ra</label><input asp-for="SoVeBanRa" type="number" min="0" placeholder="0"/><span asp-validation-for="SoVeBanRa" class="form-error"></span></div>
        <div class="form-group"><label>Lượt khách camera</label><input asp-for="LuotKhachCamera" type="number" min="0" placeholder="0"/><span asp-validation-for="LuotKhachCamera" class="form-error"></span></div>
        <div class="form-group full"><label>Doanh thu (đồng)</label><input asp-for="DoanhThu" type="number" min="0" placeholder="0"/><span asp-validation-for="DoanhThu" class="form-error"></span></div>
        <div class="form-group full"><label>Ghi chú</label><input asp-for="GhiChu" placeholder="Ghi chú thêm..."/></div>
      </div>
      <div class="form-footer">
        <a asp-action="Report" class="btn-action btn-gray"><i class="ti ti-arrow-left"></i> Quay lại</a>
        <button type="submit" class="btn-action btn-blue"><i class="ti ti-check"></i> Cập nhật</button>
      </div>
    </form>
  </div>
</div>
