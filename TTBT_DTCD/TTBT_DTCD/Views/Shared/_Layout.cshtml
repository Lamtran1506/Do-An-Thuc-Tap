@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    var username  = HttpContextAccessor.HttpContext?.Session.GetString("Username");
    var fullName  = HttpContextAccessor.HttpContext?.Session.GetString("FullName") ?? username ?? "Thành viên";
    var userRole  = HttpContextAccessor.HttpContext?.Session.GetString("Role");
    string roleLabel = userRole switch {
        "Admin"    => "Quản trị viên",
        "Staff"    => "Nhân viên",
        "Customer" => "Khách hàng",
        _ => userRole ?? ""
    };
    var ctrl   = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    bool isAuthPage = ctrl == "User" && (action == "Login" || action == "Register");
}
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>@ViewData["Title"] - Trung Tâm Bảo Tồn Di Tích Cố Đô Huế</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@3.19.0/dist/tabler-icons.min.css"/>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:"Segoe UI",Arial,sans-serif;background:#f0f2f5;color:#222;font-size:14px}

    .topbar{background:#1a4fa0;display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:56px;position:sticky;top:0;z-index:100}
    .topbar-left{display:flex;align-items:center;gap:12px}
    .topbar-logo{width:38px;height:38px;border-radius:50%;background:#fff;display:flex;align-items:center;justify-content:center}
    .topbar-logo i{font-size:22px;color:#1a4fa0}
    .topbar-name{color:#fff;font-size:13px;font-weight:600;line-height:1.3}
    .topbar-sub{color:#f5c518;font-size:11px}
    .topbar-right{display:flex;align-items:center;gap:10px;position:relative}
    .topbar-bell{color:rgba(255,255,255,.75);font-size:20px;cursor:pointer}

    .admin-wrap{position:relative}
    .admin-btn{display:flex;align-items:center;gap:7px;background:rgba(255, 255, 255, 0.12);border:1px solid rgba(255, 255, 255, 0.25);border-radius:6px;padding:6px 12px;color:#fff;font-size:13px;cursor:pointer;user-select:none}
    .admin-btn i{font-size:18px}
    .admin-wrap .dropdown{display:none;position:absolute;top:calc(100% + 8px);right:0;background:#fff;border-radius:8px;border:1px solid #e0e0e0;min-width:200px;box-shadow:0 6px 20px rgba(0,0,0,.15);overflow:hidden;z-index:200}
    .admin-wrap.open .dropdown{display:block}
    .dropdown-item{display:flex;align-items:center;gap:9px;padding:11px 16px;font-size:13px;color:#222;cursor:pointer;text-decoration:none;border-bottom:1px solid #f0f0f0}
    .dropdown-item:last-child{border-bottom:none}
    .dropdown-item:hover{background:#f5f5f5}
    .dropdown-item i{font-size:17px;color:#555}
    .dropdown-item.danger{color:#a32d2d}
    .dropdown-item.danger i{color:#a32d2d}
    .dropdown-label{padding:8px 16px;font-size:10px;text-transform:uppercase;color:#aaa;letter-spacing:.05em;border-bottom:1px solid #f0f0f0}

    .tabs{background:#1a4fa0;display:flex;gap:2px;padding:0 20px;border-bottom:2px solid rgba(255,255,255,.15);overflow-x:auto}
    .tab{padding:10px 16px;font-size:12px;font-weight:500;color:rgba(255,255,255,.65);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;border-radius:4px 4px 0 0;white-space:nowrap;text-decoration:none;display:inline-flex;align-items:center;gap:5px}
    .tab:hover {background:rgba(255,255,255,.08);color:#fff}
    .tab.active{color:#fff;background:rgba(255,255,255,.12);border-bottom-color:#f5c518}

    main{padding:18px 20px}

    .kpi-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:16px}
    .kpi-grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px}
    .kpi-card{background:#fff;border-radius:10px;padding:14px 16px;border:1px solid #e8e8e8}
    .kpi-card i{font-size:22px;margin-bottom:6px;display:block}
    .kpi-label{font-size:11px;color:#888;text-transform:uppercase;letter-spacing:.04em;margin-bottom:5px}
    .kpi-value{font-size:18px;font-weight:600;color:#1a1a1a}
    .kpi-unit{font-size:11px;color:#aaa;margin-top:2px}

    .charts-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:16px}
    .charts-row-2{display:grid;grid-template-columns:2fr 1fr;gap:12px;margin-bottom:16px}
    .two-col-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px}
    .inner-right-grid{display:grid;grid-template-columns:1fr;gap:12px}
    .card{background:#fff;border-radius:10px;border:1px solid #e8e8e8;padding:14px 16px;margin-bottom:16px}
    .card-nm{background:#fff;border-radius:10px;border:1px solid #e8e8e8;padding:14px 16px}
    .card-title{font-size:13px;font-weight:600;color:#1a1a1a;margin-bottom:10px;display:flex;align-items:center;gap:6px}
    .card-title i{font-size:16px}
    .legend-row{display:flex;gap:12px;margin-bottom:10px;flex-wrap:wrap}
    .legend-item{display:flex;align-items:center;gap:5px;font-size:11px;color:#666}
    .ldot{width:10px;height:10px;border-radius:2px;flex-shrink:0}

    .tbl{width:100%;border-collapse:collapse;font-size:12px}
    .tbl th{text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.04em;color:#888;padding:8px;border-bottom:1px solid #f0f0f0;font-weight:500;background:#fafafa}
    .tbl td{padding:10px 8px;border-bottom:1px solid #f5f5f5;color:#333;vertical-align:middle}
    .tbl tr:last-child td{border-bottom:none}
    .tbl tr:hover td{background:#f7faff}

    .badge{display:inline-block;font-size:10px;padding:2px 8px;border-radius:999px;font-weight:500}
    .b-blue{background:#e6f1fb;color:#185fa5}
    .b-green{background:#e1f5ee;color:#0f6e56}
    .b-amber{background:#faeeda;color:#854f0b}
    .b-red{background:#fcebeb;color:#a32d2d}
    .b-gray{background:#f0f0f0;color:#666}
    .b-blue-light{background:#e6f1fb;color:#1a4fa0}

    .staff-row{display:flex;align-items:center;gap:10px;margin-bottom:10px}
    .staff-row:last-child{margin-bottom:0}
    .staff-av{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;flex-shrink:0}
    .staff-name{font-size:12px;font-weight:500;color:#1a1a1a}
    .staff-role{font-size:11px;color:#888}

    .summary-row{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid #f5f5f5;font-size:12px}
    .summary-row:last-child{border-bottom:none}
    .summary-lbl{color:#666}
    .summary-val{font-weight:600;color:#1a1a1a}
    .summary-val.profit{color:#0f6e56}

    .cam-row{display:flex;align-items:center;gap:8px;margin-bottom:10px}
    .cam-row:last-child{margin-bottom:0}
    .cam-label{font-size:11px;color:#666;min-width:100px}
    .cam-bar-wrap{flex:1;height:7px;background:#f0f0f0;border-radius:4px;overflow:hidden}
    .cam-bar{height:100%;border-radius:4px;background:#1a4fa0}
    .cam-count{font-size:11px;font-weight:600;color:#333;min-width:48px;text-align:right}

    .filter-bar{display:flex;gap:10px;background:#fff;padding:12px;border-radius:8px;border:1px solid #e8e8e8;margin-bottom:12px;align-items:center;flex-wrap:wrap}
    .filter-bar select,.filter-bar input{padding:6px 10px;border:1px solid #ddd;border-radius:4px;font-size:12px;color:#444;background:#fff;outline:none}

    .btn-action{padding:6px 12px;font-size:12px;font-weight:500;border:none;border-radius:4px;cursor:pointer;display:inline-flex;align-items:center;gap:4px;text-decoration:none}
    .btn-blue{background:#1a4fa0;color:#fff}
    .btn-blue:hover{background:#163e80;color:#fff}
    .btn-gray{background:#f0f0f0;color:#333;border:1px solid #ddd}
    .btn-gray:hover{background:#e4e4e4}
    .action-icons i{cursor:pointer;font-size:16px;margin-right:4px;transition:color .2s}
    .action-icons i:hover{color:#1a4fa0}

    .user-av{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;color:#fff}
    .av-admin{background:#1a4fa0}
    .av-staff{background:#0f6e56}
    .av-customer{background:#888}
    .role-select{padding:5px 8px;border:1px solid #ddd;border-radius:4px;font-size:12px;color:#333;background:#fff;outline:none}

    .alert{padding:10px 14px;border-radius:6px;font-size:12px;margin-bottom:14px;display:flex;align-items:center;gap:8px}
    .alert-success{background:#e1f5ee;color:#0f6e56;border:1px solid #b2e4d2}
    .alert-danger{background:#fcebeb;color:#a32d2d;border:1px solid #f4c0c0}

    .access-denied{padding:40px 20px;text-align:center;color:#888}
    .access-denied i{font-size:36px;color:#dcdcdc;display:block;margin-bottom:10px}

    .form-section{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .form-group{display:flex;flex-direction:column;gap:4px}
    .form-group.full{grid-column:1/-1}
    .form-group label{font-size:11px;font-weight:600;color:#555;text-transform:uppercase;letter-spacing:.04em}
    .form-group input,.form-group select{padding:8px 11px;border:1px solid #ddd;border-radius:5px;font-size:13px;color:#222;background:#fff;outline:none}
    .form-group input:focus,.form-group select:focus{border-color:#1a4fa0;box-shadow:0 0 0 2px rgba(26,79,160,.08)}
    .form-error{color:#a32d2d;font-size:11px;margin-top:2px}
    .login-link{color:#1a4fa0;font-size:12px;text-decoration:none}
    .login-link:hover{text-decoration:underline}
  </style>

  <style>
    @@media (max-width: 900px) {
      .kpi-grid, .kpi-grid-4 { grid-template-columns: repeat(2, 1fr) !important; }
      .charts-row, .charts-row-2, .two-col-grid { grid-template-columns: 1fr !important; }
      .form-section { grid-template-columns: 1fr !important; }
    }
  </style>
</head>
<body>

@if (!isAuthPage && username != null)
{
  <div class="topbar">
    <div class="topbar-left">
      <div class="topbar-logo"><i class="ti ti-building-arch"></i></div>
      <div>
        <div class="topbar-name">CỔNG THÔNG TIN ĐIỆN TỬ</div>
        <div class="topbar-sub">TRUNG TÂM BẢO TỒN DI TÍCH CỐ ĐÔ HUẾ</div>
      </div>
    </div>
    <div class="topbar-right">
      <i class="ti ti-bell topbar-bell"></i>
      <div class="admin-wrap">
        <div class="admin-btn" id="adminBtn">
          <i class="ti ti-user-circle"></i>
          <span>@fullName</span>
          <i class="ti ti-chevron-down" style="font-size:13px;opacity:.6"></i>
        </div>
        <div class="dropdown">
          <div class="dropdown-label">@roleLabel</div>
          <a href="@Url.Action("Logout", "User")" class="dropdown-item danger">
            <i class="ti ti-logout"></i> Đăng xuất
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="tabs">
    <a href="@Url.Action("Index","Home")" class="tab @(ctrl=="Home" && action=="Index" ? "active" : "")">
      <i class="ti ti-layout-dashboard"></i> Dashboard
    </a>

    @if (userRole == "Admin" || userRole == "Staff")
    {
      <a href="@Url.Action("ChinhSuaDanhMuc","Home")" class="tab @(ctrl=="Home" && action=="ChinhSuaDanhMuc" ? "active" : "")">
        <i class="ti ti-settings"></i> Chỉnh sửa danh mục
      </a>
    }

    @if (userRole == "Admin")
    {
      <a href="@Url.Action("Users","Admin")" class="tab @(ctrl=="Admin" && action=="Users" ? "active" : "")">
        <i class="ti ti-shield-lock"></i> Phân quyền
      </a>
    }
  </div>
}

<main>@RenderBody()</main>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const wrap = document.querySelector(".admin-wrap");
    const btn  = document.getElementById("adminBtn");
    if (!wrap || !btn) return;
    btn.addEventListener("click", function (e) {
      e.stopPropagation();
      wrap.classList.toggle("open");
    });
    document.addEventListener("click", function (e) {
      if (!wrap.contains(e.target)) wrap.classList.remove("open");
    });
  });
</script>
</body>
</html>