@{
    ViewData["Title"] = "Đăng nhập";
    // Tách trang Đăng nhập khỏi Layout chung để tự quản lý CSS độc lập, tránh bị vỡ giao diện
    Layout = null; 
}

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] - Trung Tâm Bảo Tồn Di Tích Cố Đô Huế</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@3.19.0/dist/tabler-icons.min.css" />
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    body {
      font-family: "Segoe UI", Arial, sans-serif;
      /* Background dải màu Gradient kết hợp tone xanh hoàng gia thẫm sang trọng của di tích */
      background: linear-gradient(135deg, #0f3069 0%, #1a4fa0 50%, #2e6bc6 100%);
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #333;
    }

    .login-container {
      width: 100%;
      max-width: 420px;
      padding: 20px;
    }

    /* Card Đăng nhập đổ bóng, bo góc hiện đại */
    .login-box {
      background: rgba(255, 255, 255, 0.96);
      border-radius: 16px;
      padding: 35px 30px;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.25);
      border: 1px solid rgba(255, 255, 255, 0.2);
    }

    /* Thiết kế Header của Form đồng bộ thương hiệu */
    .login-logo {
      text-align: center;
      margin-bottom: 28px;
    }
    .login-icon {
      width: 60px;
      height: 60px;
      background: #1a4fa0;
      color: #fff;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 32px;
      margin-bottom: 12px;
      border: 2px solid #f5c518; /* Viền màu vàng Gold */
      box-shadow: 0 4px 10px rgba(26, 79, 160, 0.3);
    }
    .login-title {
      color: #1a4fa0;
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 0.05em;
      line-height: 1.4;
    }
    .login-sub {
      color: #b08400; /* Màu vàng đậm sang trọng */
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.03em;
      margin-top: 2px;
    }

    /* Hộp thông báo lỗi và thông báo thành công */
    .login-error {
      background: #fcebeb;
      color: #a32d2d;
      padding: 10px 14px;
      border-radius: 8px;
      font-size: 13px;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      border: 1px solid #f5c2c2;
    }
    .alert-success {
      background: #e1f5ee;
      color: #0f6e56;
      padding: 10px 14px;
      border-radius: 8px;
      font-size: 13px;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      border: 1px solid #a3e0ca;
    }

    /* Định dạng các ô Input */
    .login-field {
      margin-bottom: 18px;
      position: relative;
    }
    .login-field label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      color: #555;
      margin-bottom: 6px;
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }
    .input-wrapper {
      position: relative;
    }
    .input-wrapper i {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: #888;
      font-size: 18px;
    }
    .login-field input {
      width: 100%;
      padding: 11px 12px 11px 40px;
      border: 1px solid #ccd0d5;
      border-radius: 8px;
      font-size: 14px;
      outline: none;
      transition: all 0.25s;
      background: #f9fafb;
    }
    .login-field input:focus {
      border-color: #1a4fa0;
      background: #fff;
      box-shadow: 0 0 0 3px rgba(26, 79, 160, 0.15);
    }

    /* Nút bấm Đăng nhập nổi bật màu Cam hoàng hôn từ logo di tích */
    .login-btn {
      width: 100%;
      padding: 12px;
      background: #ff6f43; /* Màu cam giống nút MUA VÉ ở trang chủ di tích */
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
      box-shadow: 0 4px 12px rgba(255, 111, 67, 0.25);
    }
    .login-btn:hover {
      background: #e6562b;
      box-shadow: 0 4px 15px rgba(255, 111, 67, 0.4);
    }

    .login-divider {
      text-align: center;
      margin: 20px 0;
      font-size: 12px;
      color: #aaa;
    }

    .login-link {
      display: block;
      text-align: center;
      color: #1a4fa0;
      font-size: 13px;
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s;
    }
    .login-link:hover {
      color: #0f3069;
      text-decoration: underline;
    }
  </style>
</head>
<body>

<div class="login-container">
  <div class="login-box">
    <div class="login-logo">
      <div class="login-icon"><i class="ti ti-building-arch"></i></div>
      <div class="login-title">CỔNG THÔNG TIN ĐIỆN TỬ</div>
      <div class="login-sub">TRUNG TÂM BẢO TỒN DI TÍCH CỐ ĐÔ HUẾ</div>
    </div>

    @if (ViewBag.Error != null)
    {
      <div class="login-error">
        <i class="ti ti-alert-circle" style="margin-right:8px"></i> @ViewBag.Error
      </div>
    }

    @if (TempData["Message"] != null)
    {
      <div class="alert alert-success">
        <i class="ti ti-check" style="margin-right:8px"></i> @TempData["Message"]
      </div>
    }

    <form asp-action="Login" method="post">
      <div class="login-field">
        <label for="username">Tên đăng nhập</label>
        <div class="input-wrapper">
          <i class="ti ti-user"></i>
          <input type="text" id="username" name="username" autocomplete="username"
                 placeholder="Nhập tên tài khoản" required />
        </div>
      </div>
      <div class="login-field">
        <label for="password">Mật khẩu</label>
        <div class="input-wrapper">
          <i class="ti ti-lock"></i>
          <input type="password" id="password" name="password" autocomplete="current-password"
                 placeholder="Nhập mật khẩu" required />
        </div>
      </div>
      <button type="submit" class="login-btn">
        <i class="ti ti-login" style="margin-right:6px"></i> Đăng nhập hệ thống
      </button>
    </form>

    <div class="login-divider">— hoặc —</div>
    <a asp-controller="User" asp-action="Register" class="login-link">
      Chưa có tài khoản đăng nhập? Đăng ký ngay
    </a>
  </div>
</div>

</body>
</html>