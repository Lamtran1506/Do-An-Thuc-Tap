@{
    ViewData["Title"] = "Quản lý doanh thu - Trung Tâm Bảo Tồn Di Tích Cố Đô Huế";
    Layout = "_Layout";
}

<div class="kpi-grid-4">
  <div class="kpi-card">
    <i class="ti ti-trending-up" style="color: #1a4fa0"></i>
    <div class="kpi-label">Tổng doanh thu</div>
    <div class="kpi-value">500.000.000đ</div>
    <div class="kpi-unit" style="color: #0f6e56">▲ 12.5% so với kỳ trước</div>
  </div>
  <div class="kpi-card">
    <i class="ti ti-ticket" style="color: #0f6e56"></i>
    <div class="kpi-label">Doanh thu bán vé</div>
    <div class="kpi-value">100.000.000đ</div>
    <div class="kpi-unit" style="color: #0f6e56">▲ 8.3% so với kỳ trước</div>
  </div>
  <div class="kpi-card">
    <i class="ti ti-tools-kitchen" style="color: #854f0b"></i>
    <div class="kpi-label">Doanh thu dịch vụ khác</div>
    <div class="kpi-value">400.000.000đ</div>
    <div class="kpi-unit" style="color: #0f6e56">▲ 15.7% so với kỳ trước</div>
  </div>
  <div class="kpi-card">
    <i class="ti ti-receipt" style="color: #533ab7"></i>
    <div class="kpi-label">Số giao dịch</div>
    <div class="kpi-value">1.250</div>
    <div class="kpi-unit" style="color: #0f6e56">▲ 10.1% so với kỳ trước</div>
  </div>
</div>

<div class="charts-row-2">
  <div class="card-nm">
    <div class="card-title"><i class="ti ti-chart-bar" style="color: #1a4fa0"></i>BIỂU ĐỒ DOANH THU THEO THỜI GIAN</div>
    <div class="legend-row">
      <span class="legend-item"><span class="ldot" style="background: #1a4fa0"></span>Doanh thu bán vé</span>
      <span class="legend-item"><span class="ldot" style="background: #f5c518"></span>Doanh thu dịch vụ khác</span>
    </div>
    <div style="position: relative; height: 220px">
      <canvas id="revBarChart"></canvas>
    </div>
  </div>
  <div class="card-nm">
    <div class="card-title"><i class="ti ti-chart-pie" style="color: #854f0b"></i>TỶ TRỌNG DOANH THU</div>
    <div style="position: relative; height: 160px; margin-bottom: 10px">
      <canvas id="revPieChart"></canvas>
    </div>
    <div style="font-size: 11px; color: #555; display: flex; flex-direction: column; gap: 5px;">
      <div class="legend-item"><span class="ldot" style="background: #1a4fa0"></span>Vé: 100Tr (20%)</div>
      <div class="legend-item"><span class="ldot" style="background: #f5c518"></span>Dịch vụ khác: 400Tr (80%)</div>
    </div>
  </div>
</div>

<div class="filter-bar">
  <input type="date" value="2025-08-01" />
  <span style="font-size: 12px; color: #888">đến</span>
  <input type="date" value="2025-08-05" />
  <select>
    <option>Tất cả loại doanh thu</option>
    <option>Bán vé</option>
    <option>Dịch vụ lưu trú</option>
  </select>
  <select>
    <option>Tất cả điểm thu</option>
    <option>Đại Nội</option>
    <option>Lăng Khải Định</option>
  </select>
  <input type="text" placeholder="Tìm kiếm..." style="flex: 1; max-width: 200px" />
  <button class="btn-action btn-blue"><i class="ti ti-refresh"></i> Làm mới</button>
</div>

<div class="card-nm" style="padding: 0; overflow: hidden;">
  <table class="tbl">
    <thead>
      <tr>
        <th>Ngày</th>
        <th>Loại doanh thu</th>
        <th>Số tiền (đồng)</th>
        <th>Điểm thu</th>
        <th>Nhân viên phụ trách</th>
        <th>Nhân viên lập</th>
        <th style="text-align: center">Thao tác</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>05/08/2025</td>
        <td><span class="badge b-blue">Bán vé</span></td>
        <td><strong>20.000.000</strong></td>
        <td>Đại Nội</td>
        <td>Nguyễn Văn A</td>
        <td>Mỹ</td>
        <td class="action-icons" style="text-align: center">
          <i class="ti ti-eye"></i><i class="ti ti-pencil" style="color: #854f0b"></i><i class="ti ti-trash" style="color: #a32d2d"></i>
        </td>
      </tr>
      <tr>
        <td>05/08/2025</td>
        <td><span class="badge b-green">Dịch vụ lưu trú</span></td>
        <td><strong>50.000.000</strong></td>
        <td>Lăng Khải Định</td>
        <td>Lê Thị B</td>
        <td>Mỹ</td>
        <td class="action-icons" style="text-align: center">
          <i class="ti ti-eye"></i><i class="ti ti-pencil" style="color: #854f0b"></i><i class="ti ti-trash" style="color: #a32d2d"></i>
        </td>
      </tr>
      <tr>
        <td>04/08/2025</td>
        <td><span class="badge b-blue">Bán vé</span></td>
        <td><strong>18.000.000</strong></td>
        <td>Chùa Thiên Mụ</td>
        <td>Trần Đình C</td>
        <td>Mỹ</td>
        <td class="action-icons" style="text-align: center">
          <i class="ti ti-eye"></i><i class="ti ti-pencil" style="color: #854f0b"></i><i class="ti ti-trash" style="color: #a32d2d"></i>
        </td>
      </tr>
    </tbody>
  </table>
</div>

<script>
  const tcColor = "#999";
  
  new Chart(document.getElementById("revBarChart"), {
    type: "bar",
    data: {
      labels: ["03/2025", "04/2025", "05/2025", "06/2025", "07/2025"],
      datasets: [
        { label: "Doanh thu bán vé", data: [180, 200, 190, 320, 230], backgroundColor: "#1a4fa0", borderRadius: 3 },
        { label: "Doanh thu dịch vụ khác", data: [400, 520, 300, 420, 200], backgroundColor: "#f5c518", borderRadius: 3 }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { display: false }, ticks: { color: tcColor, font: { size: 10 } } },
        y: { grid: { color: "rgba(0,0,0,0.05)" }, ticks: { color: tcColor, font: { size: 10 } } }
      }
    }
  });

  new Chart(document.getElementById("revPieChart"), {
    type: "pie",
    data: {
      labels: ["Bán vé", "Dịch vụ khác"],
      datasets: [{ data: [20, 80], backgroundColor: ["#1a4fa0", "#f5c518"], borderWidth: 0 }]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
  });
</script>