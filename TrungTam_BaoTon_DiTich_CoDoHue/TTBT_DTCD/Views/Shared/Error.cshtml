@model TTBT_DTCD.Models.ErrorViewModel
@{ ViewData["Title"] = "Lỗi"; }

<div class="body">
  <div class="access-denied">
    <i class="ti ti-alert-circle" style="font-size:48px;color:#a32d2d"></i>
    <div style="font-size:18px;font-weight:600;color:#333;margin-top:10px">Đã xảy ra lỗi</div>
    @if (Model.ShowRequestId)
    {
      <p style="font-size:12px;color:#888;margin-top:6px">Request ID: <code>@Model.RequestId</code></p>
    }
    <a asp-controller="Home" asp-action="Index" class="btn-action btn-blue" style="margin-top:16px;display:inline-flex">
      <i class="ti ti-arrow-left"></i> Quay về Dashboard
    </a>
  </div>
</div>
